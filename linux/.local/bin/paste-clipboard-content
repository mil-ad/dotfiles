#!/usr/bin/env bash

# I have experimented with Shift+Insert and Ctrl+Shift+V with both ydotool and
# wtype to varying levels success

assert_installed ydotool
# (Left)Shift: 42
# Insert: 110
ydotool key 42:1 110:1 42:0 110:0

