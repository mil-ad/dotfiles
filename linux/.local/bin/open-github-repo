#!/usr/bin/env bash

# Opens one of my GitHub repos in the browser. The cache is populated by
# refresh-github-caches (also kept warm by a systemd timer).

assert_installed jq rofimenu refresh-github-caches

cache_file="$HOME/.cache/github_repos"

function maybe_regenerate_cache {
    if test "$(find "$cache_file" -mmin +2)"
    then
        refresh-github-caches
    fi
}

[ ! -e "$cache_file" ] && refresh-github-caches

# A single jq pass emits "url<TAB>name" per repo; mapfile slurps it into an array
# so we don't parse the cache twice. rofimenu shows just the name column and
# `-format i` hands back the row index straight into the array.
mapfile -t rows < <(jq -r '.url + "\t" + .name' "$cache_file")

selected_idx=$(printf '%s\n' "${rows[@]}" | cut -f2- | rofimenu -format i)

if [ -n "$selected_idx" ] && [ "$selected_idx" -ge 0 ]; then
    xdg-open "${rows[$selected_idx]%%$'\t'*}"
fi

maybe_regenerate_cache
