#!/usr/bin/env bash

file="$1"

# Inner mode: invoked inside the kitty popup to run fzf
if [ "$2" = "--select" ]; then
    yq -o=json < "$file" \
      | jq -r 'to_entries[] | "\(.key)\t\(.value.name)"' \
      | fzf --delimiter=$'\t' --with-nth=2 \
            --no-separator --reverse --prompt='' --pointer='' --no-info \
            --color='gutter:#222222,bg+:#d79921,fg+:#282828,hl+:#8f3f71,fg:#d5c4a1,hl:#d79921' \
            --preview "i={1}; yq -r \".[\$i].value\" \"$file\" | bat --color=always -pp -l yaml" \
            --preview-window=right:60%:wrap
    exit
fi

assert_installed yq jq fzf bat wl-copy paste-clipboard-content kitty kitty-app

selected_line=$(KITTY_APP_REDIRECT_STDOUT=1 \
    KITTY_EXTRA_OPTS='--override background=#222222 --override "window_padding_width=0.5 5" --override cursor_shape=beam --class fzfmenu' \
    kitty-app "$0" "$file" --select)

selected_idx=$(echo "$selected_line" | cut -f1)
[ -z "$selected_idx" ] && exit

yq -r ".[$selected_idx].value" "$file" | sed -z '$s/\n$//' | wl-copy && paste-clipboard-content
