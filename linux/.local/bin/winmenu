#!/usr/bin/env bash

set -e

mapfile -t windows < <(swaymsg -t get_tree |
	jq -r '.. | objects
		| select(.type == "con" and (.app_id != null or .window_properties.class != null))
		| "\(.id)\t\(.name)"')

index=$(printf '%s\n' "${windows[@]}" | cut -f2- | rofimenu -format i)

swaymsg "[con_id=${windows[$index]%%$'\t'*}] focus"
