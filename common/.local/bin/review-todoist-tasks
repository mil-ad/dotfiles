#!/usr/bin/env bash

assert_installed jq curl rofimenu || exit 1
assert_defined TODOIST_TOKEN || exit 1

all_tasks="[]"
cursor=""
while :; do
    url="https://api.todoist.com/api/v1/tasks?limit=200"
    [[ -n $cursor ]] && url="$url&cursor=$cursor"
    resp=$(curl --silent "$url" -H "Authorization: Bearer $TODOIST_TOKEN")
    all_tasks=$(jq -n --argjson a "$all_tasks" --argjson b "$(jq .results <<< "$resp")" '$a + $b')
    cursor=$(jq -r '.next_cursor // ""' <<< "$resp")
    [[ -z $cursor ]] && break
done
sorted_resp=$(jq 'sort_by(.order)' <<< "$all_tasks")

indices=$(echo "$sorted_resp" | jq -r ".[].content" | rofimenu -multi-select -format i)

[[ -z $indices ]] && exit 1

exit_code=0
for index in $indices; do
    task_id=$(echo "$sorted_resp" | jq -r ".[$index].id")
    task_content=$(echo "$sorted_resp" | jq ".[$index].content")
    resp=$(curl -X POST "https://api.todoist.com/api/v1/tasks/$task_id/close" \
      -H "Authorization: Bearer $TODOIST_TOKEN")

    if [ $? -eq 0 ]; then
        notify-send -i " " "✅ Marked as done:" "$task_content"
    else
        exit_code=1
        notify-send -u critical " " "❌ Could NOT mark task as done:" "$task_content"
    fi
done

exit $exit_code
