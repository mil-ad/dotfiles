#!/usr/bin/env bash
#
# Extract an archive without tarbombing the current directory: if the archive
# holds a single top-level entry it's extracted as-is, otherwise its contents
# are wrapped in a directory named after the archive. On success the original
# archive is moved to the trash via trash-put (or, if that's not installed,
# you're asked whether to delete it).
#
# With -t/--touch the extracted files' timestamps are reset to now, instead of
# keeping the (often stale) mtimes recorded in the archive.

set -euo pipefail

touch=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    -t|--touch) touch=true; shift ;;
    --) shift; break ;;
    -*) echo "extract: unknown option '$1'" >&2; exit 1 ;;
    *) break ;;
  esac
done

file=${1:?usage: extract [-t|--touch] ARCHIVE}
[ -f "$file" ] || { echo "extract: '$file' is not a file" >&2; exit 1; }

# Stage into a temp dir so we can decide on the layout before touching cwd.
tmp=$(mktemp -d ./.extract.XXXXXX)
trap 'rm -rf "$tmp"' EXIT

case "$file" in
  *.tar.gz|*.tgz)   assert_installed tar;   tar xzf "$file" -C "$tmp" ;;
  *.tar.bz2|*.tbz2) assert_installed tar;   tar xjf "$file" -C "$tmp" ;;
  *.tar.zst|*.tzst) assert_installed tar; assert_installed zstd; tar --zstd -xf "$file" -C "$tmp" ;;
  *.tar)            assert_installed tar;   tar xf  "$file" -C "$tmp" ;;
  *.zip)            assert_installed unzip; unzip -q "$file" -d "$tmp" ;;
  *.rar)            assert_installed unrar; unrar x "$file" "$tmp/" ;;
  *) echo "extract: don't know how to extract '$file'" >&2; exit 1 ;;
esac

# Archive base name, used only when we need a wrapper directory.
name=$(basename "$file"); name=${name%.*}; name=${name%.tar}

shopt -s nullglob dotglob
entries=("$tmp"/*)

if [ "${#entries[@]}" -eq 1 ]; then
  target=$(basename "${entries[0]}")
else
  target=$name
fi

[ -e "./$target" ] && { echo "extract: './$target' already exists" >&2; exit 1; }

if [ "${#entries[@]}" -eq 1 ]; then
  mv "${entries[0]}" "./$target"   # single entry: lift it out, trap cleans tmp
else
  mv "$tmp" "./$target"            # many entries: the staging dir becomes target
  trap - EXIT
fi

if [ "$touch" = true ]; then
  find "./$target" -exec touch {} +
  echo "extract: reset timestamps of './$target' to now"
fi

echo "✅ extract: extracted '$file' into './$target'"

# Extraction succeeded (set -e would have aborted otherwise) — dispose of the original.
if command -v trash-put >/dev/null 2>&1; then
  trash-put -- "$file" && echo "extract: moved '$file' to trash"
else
  printf "extract: delete original '%s'? [y/N] " "$file" >&2
  read -r reply </dev/tty || reply=""
  case "$reply" in
    [yY]|[yY][eE][sS]) rm -f -- "$file"; echo "extract: deleted '$file'" ;;
    *) echo "extract: kept '$file'" ;;
  esac
fi
