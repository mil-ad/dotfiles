#!/usr/bin/env bash

# Refreshes the GitHub caches consumed by open-github-pr-or-issue and
# open-github-repo. Auth and pagination are handled by the gh CLI.
#
# The PR/issue and repos fetches are independent, so they run concurrently; the
# two PR/issue searches (open + recently-closed) likewise run in parallel.

set -euo pipefail

assert_installed gh jq flock

# Single-instance guard: opening the menus in quick succession (or overlapping
# the systemd timer) would otherwise kick off several full refreshes at once.
# Wait up to a minute for any in-flight refresh; if it's still holding the lock
# after that it's probably wedged, so notify and bail rather than pile on.
exec 9>"$HOME/.cache/github_refresh.lock"
if ! flock -w 60 9; then
    notify-send "refresh-github-caches" "Another refresh is still running after 60s; giving up." 2>/dev/null || true
    exit 1
fi

pr_or_issue_cache="$HOME/.cache/github_pr_or_issue"
repos_cache="$HOME/.cache/github_repos"

# Best-effort desktop notification on failure (offline, auth expired, rate
# limited). Without it the menus would just keep serving stale data silently.
function fail {
    notify-send "refresh-github-caches" "$1" 2>/dev/null || true
    exit 1
}

# PRs and issues that involve me: everything still open, plus anything closed
# (or, for PRs, merged) in the last fortnight. Two disjoint searches run in
# parallel. gh returns the raw REST JSON shape, so consumers can read
# .pull_request / .state / .state_reason / .draft for colouring. Newest-updated
# first. Each gh exit is checked so a partial/failed fetch never overwrites the
# cache (set -e aborts before the mv).
function refresh_pr_or_issue {
    local since t_open t_closed p_open p_closed
    since=$(date -d '14 days ago' +%F)
    t_open=$(mktemp) t_closed=$(mktemp)
    gh api --paginate -X GET search/issues -f q="involves:mil-ad state:open"      --jq '.items[]' > "$t_open"   & p_open=$!
    gh api --paginate -X GET search/issues -f q="involves:mil-ad closed:>=$since" --jq '.items[]' > "$t_closed" & p_closed=$!
    wait "$p_open"
    wait "$p_closed"
    jq -s '{items: sort_by(.updated_at) | reverse}' "$t_open" "$t_closed" > "$pr_or_issue_cache.tmp"
    mv "$pr_or_issue_cache.tmp" "$pr_or_issue_cache"
    rm -f "$t_open" "$t_closed"
}

# Repos I own / collaborate on / belong to, most-recently-pushed first.
function refresh_repos {
    gh api --paginate -X GET user/repos \
        -f affiliation=owner,collaborator,organization_member -f sort=push \
        --jq '.[] | {name: .full_name, url: .html_url}' > "$repos_cache.tmp"
    mv "$repos_cache.tmp" "$repos_cache"
}

# Atomic writes (.tmp -> mv) mean a reader never sees a half-written cache, even
# though both jobs run at once. Wait on each PID and surface any failure once.
refresh_pr_or_issue & pr_pid=$!
refresh_repos & repos_pid=$!
ok=1
wait "$pr_pid"    || ok=0
wait "$repos_pid" || ok=0
[ "$ok" -eq 1 ] || fail "Couldn't refresh GitHub caches (offline, auth expired, or rate limited?)"
